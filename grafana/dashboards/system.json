{
  "dashboard": {
    "id": null,
    "uid": "econet-system",
    "title": "EcoNet Grant - System",
    "tags": ["econet", "system"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "1h",
    "time": {
      "from": "now-7d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Work State Over Time",
        "type": "state-timeline",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "fillOpacity": 70
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "refId": "A",
            "datasource": { "type": "influxdb", "uid": "" },
            "query": "from(bucket: \"econet_grant\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r.entity_id == \"sensor.econet_grant_work_state\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> aggregateWindow(every: 5m, fn: last, createEmpty: false)"
          }
        ]
      },
      {
        "id": 2,
        "title": "Heat Source Preset Temperature",
        "type": "timeseries",
        "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "refId": "A",
            "datasource": { "type": "influxdb", "uid": "" },
            "query": "from(bucket: \"econet_grant\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r.entity_id == \"sensor.econet_grant_heat_source_preset_temperature\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> aggregateWindow(every: 5m, fn: mean, createEmpty: false)"
          }
        ]
      },
      {
        "id": 3,
        "title": "Buffer Temperature",
        "type": "timeseries",
        "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "refId": "A",
            "datasource": { "type": "influxdb", "uid": "" },
            "query": "from(bucket: \"econet_grant\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r.entity_id == \"sensor.econet_grant_buffer_temperature_lower\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> aggregateWindow(every: 5m, fn: mean, createEmpty: false)"
          }
        ]
      },
      {
        "id": 4,
        "title": "All Temperatures Overview",
        "type": "timeseries",
        "gridPos": { "h": 12, "w": 24, "x": 0, "y": 18 },
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "custom": {
              "lineWidth": 1,
              "fillOpacity": 5,
              "spanNulls": true
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "refId": "A",
            "datasource": { "type": "influxdb", "uid": "" },
            "query": "from(bucket: \"econet_grant\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"°C\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> aggregateWindow(every: 10m, fn: mean, createEmpty: false)"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
